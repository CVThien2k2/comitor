model Message {
  id                String        @id @default(uuid())
  conversationId    String        @map("conversation_id")
  senderType        MessageSender @map("sender_type")
  accountCustomerId String?       @map("account_customer_id")
  quoteMessageId    String?       @map("quote_message_id")

  content    Json?         @map("content") @db.JsonB
  status     MessageStatus @default(processing) @map("status")
  isRead     Boolean       @default(false) @map("is_read")
  externalId String?       @map("external_id") @db.VarChar(255)
  timestamp  DateTime      @default(now()) @map("timestamp")
  type       MessageType   @map("type")

  createdBy String?  @map("created_by_id")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  conversation    Conversation     @relation(fields: [conversationId], references: [id])
  accountCustomer AccountCustomer? @relation(fields: [accountCustomerId], references: [id])
  createdByUser   User?            @relation(fields: [createdBy], references: [id])
  quoteMessage    Message?         @relation("QuoteMessage", fields: [quoteMessageId], references: [id])
  quotedMessages  Message[]        @relation("QuoteMessage")

  @@index([conversationId], name: "conversation_id")
  @@index([conversationId, timestamp(sort: Desc), id(sort: Desc)], name: "conversation_timestamp_id_desc")
  @@index([accountCustomerId], name: "message_account_customer_id")
  @@map("messages")
}
