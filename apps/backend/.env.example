PORT=8000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
PRISMA_QUERY_LOG=false
DATABASE_URL=postgresql://postgres:password@localhost:5432/comitor

JWT_SECRET=comitor-access-secret-change-me
JWT_REFRESH_SECRET=comitor-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_URL=redis://:@localhost:6379
REDIS_CACHE_TTL=300

ZALO_OA_ID=
ZALO_OA_SECRET_KEY=
ZALO_OA_API_URL=https://openapi.zalo.me
ZALO_OA_AUTH_API_URL=https://oauth.zaloapp.com

META_APP_ID=
META_APP_SECRET_KEY=
META_VERIFY_TOKEN=
META_REDIRECT_URI=
# AWS S3
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=comitor
AWS_REGION=ap-southeast-1

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@comitor.app
