model ProviderCredentials {
  id                    String         @id @default(uuid())
  credentialType        CredentialType @map("credential_type")
  accessToken           String?        @map("access_token")
  refreshToken          String?        @map("refresh_token")
  accessTokenExpiresAt  DateTime?      @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime?      @map("refresh_token_expires_at")
  credentialPayload     Json?          @map("credential_payload")
  linkAccountId         String         @unique @map("link_account_id")

  linkAccount LinkAccount @relation(fields: [linkAccountId], references: [id], onDelete: Cascade)

  @@map("provider_credential")
}
