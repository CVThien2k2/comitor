model AccountCustomer {
  id              String    @id @default(uuid())
  accountId       String    @map("account_id")
  linkedAccountId String    @map("linked_account_id")
  goldenProfileId String    @map("golden_profile_id")
  avatarUrl       String?   @map("avatar_url")
  isOnline        Boolean   @default(false) @map("is_online")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime? @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  linkedAccount         LinkAccount            @relation(fields: [linkedAccountId], references: [id], onDelete: Cascade)
  goldenProfile         GoldenProfile          @relation(fields: [goldenProfileId], references: [id], onDelete: Cascade)
  conversationCustomers ConversationCustomer[]
  messages              Message[]              @relation("MessageAccountCustomer")
  createdConversations  Conversation[]         @relation("ConversationCreator")

  @@unique([accountId, linkedAccountId], name: "unique_account_customer")
  @@map("account_customer")
}
