model ConversationCustomer {
  conversationId    String  @map("conversation_id")
  accountCustomerId String  @map("account_customer_id")
  isAdmin           Boolean @default(false) @map("is_admin")

  conversation    Conversation    @relation(fields: [conversationId], references: [id])
  accountCustomer AccountCustomer @relation(fields: [accountCustomerId], references: [id])

  @@unique([conversationId, accountCustomerId], name: "unique_conversation_customer")
  @@map("conversation_customers")
}
