model User {
  id            String  @id @default(uuid())
  name          String
  email         String  @unique
  username      String  @unique
  password      String
  emailVerified Boolean @default(false) @map("email_verified")
  avatarUrl     String? @map("avatar_url")
  phone         String? @unique @map("phone")
  roleId        String? @map("role_id") //ID role của người dùng
  agentLevelId  String? @map("agent_level_id") //ID agent level của người dùng
  isActive      Boolean @default(true) @map("is_active")
  isOnline      Boolean @default(false) @map("is_online")

  countProcessing   Int     @default(0) @map("count_processing_sessions") //Số lượng khách đang xử lý
  isReadyProcessing Boolean @default(true) @map("is_ready_processing") //Người dùng có sẵn sàng xử lý khách hàng hay không

  createdBy String   @map("created_by_id")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  role                      Role?              @relation(fields: [roleId], references: [id])
  createdByUser             User               @relation("UserCreatedBy", fields: [createdBy], references: [id]) //Tạo bởi
  linkAccounts              LinkAccount[]
  sentMessages              Message[]
  refreshTokens             RefreshToken[]
  createdUsers              User[]             @relation("UserCreatedBy") //Danh sách người dùng đã tạo
  roles                     Role[]             @relation("RoleCreatedBy") //Danh sách roles đã tạo
  permissions               Permission[]       @relation("PermissionCreatedBy") //Danh sách permissions đã tạo
  suggestedMessages         SuggestedMessage[] @relation("SuggestedMessageCreatedBy") //Danh sách suggested messages đã tạo
  sessionAssignees          SessionAssignee[]  @relation("ProcessingSessionAssignBy") //Danh sách session assignees đã tạo
  processedSessionAssignees SessionAssignee[]  @relation("ProcessingSessionAssignee") //Danh sách session assignees đã xử lý
  agentLevel                AgentLevel?        @relation(fields: [agentLevelId], references: [id])
  agentLevelCreated         AgentLevel[]       @relation("AgentLevelCreatedBy") //Danh sách agent levels đã tạo

  @@map("user")
}
