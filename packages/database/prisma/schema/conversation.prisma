model Conversation {
  id                String           @id @default(uuid())
  linkedAccountId   String           @map("linked_account_id")
  name              String?
  idGroup           String?          @map("id_group")
  type              ConversationType @default(personal)
  tag               ConversationTag  @default(other)
  journeyState      JourneyState?    @map("journey_state")
  metadata          Json?
  lastActivityAt    DateTime?        @map("last_activity_at")
  lastInboundAt     DateTime?        @map("last_inbound_at")
  lastOutboundAt    DateTime?        @map("last_outbound_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  accountCustomerId String?          @map("account_customer_id")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  linkedAccount         LinkAccount            @relation(fields: [linkedAccountId], references: [id], onDelete: Cascade)
  accountCustomer       AccountCustomer?       @relation("ConversationCreator", fields: [accountCustomerId], references: [id], onDelete: Cascade)
  conversationCustomers ConversationCustomer[]
  messages              Message[]

  @@index([lastActivityAt], name: "last_activity_at")
  @@map("conversations")
}
