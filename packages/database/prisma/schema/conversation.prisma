model Conversation {
  id              String           @id @default(uuid())
  linkedAccountId String           @map("linked_account_id")
  name            String           @map("name")
  avatarUrl       String?          @map("avatar_url")
  externalId      String?          @map("external_id")
  type            ConversationType @default(personal)
  tag             ConversationTag  @default(other)
  journeyState    JourneyState?    @map("journey_state")

  status              ConversationStatus @default(pending) @map("status") //Trạng thái cuộc hội thoại
  countUnreadMessages Int                @default(0) @map("count_unread_messages") //Số lượng tin nhắn chưa đọc
  isUnread            Boolean            @default(false) @map("is_unread") //Cuộc hội thoại có tin nhắn chưa đọc hay không
  processingBy        String?            @map("processing_by_user_id") //ID người dùng đang xử lý cuộc hội thoại\

  lastActivityAt DateTime  @map("last_activity_at")
  lastViewedAt   DateTime? @map("last_viewed_at")

  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  linkedAccount         LinkAccount            @relation(fields: [linkedAccountId], references: [id])
  conversationCustomers ConversationCustomer[]
  processingSessions    ProcessingSession[]
  messages              Message[]
  processingByUser      User?                  @relation("ProcessingConversation", fields: [processingBy], references: [id])

  @@index([lastActivityAt(sort: Desc)], name: "last_activity_at")
  @@index([linkedAccountId], name: "linked_account_id")
  @@index([lastViewedAt(sort: Desc)], name: "last_viewed_at")
  @@map("conversations")
}
